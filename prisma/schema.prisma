generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id                String    @id @default(uuid())
  description       String
  amount            Float
  category          String
  transactionDate   DateTime
  isInstallment     Boolean
  installmentNumber Int?
  totalInstallments Int?
  purchaseId        String?
  isRecurring       Boolean
  recurringId       String?
  createdAt         DateTime  @default(now())
}